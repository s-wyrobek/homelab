# Copy this file to `.env` and replace every value before running `docker compose up`.
# Never commit the real `.env` — it is excluded by .gitignore.

# --- MariaDB ---------------------------------------------------------------
MYSQL_ROOT_PASSWORD=change-me-strong-root-password
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=change-me-strong-db-password

# --- Nextcloud admin -------------------------------------------------------
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-strong-admin-password

# --- Networking ------------------------------------------------------------
# Space-separated list of hostnames the instance is reachable on.
NEXTCLOUD_TRUSTED_DOMAINS=nextcloud.home 192.168.1.120

# When a reverse proxy terminates TLS, set to `https`. Until then, leave as `http`.
OVERWRITEPROTOCOL=http

# Reverse proxy IP only — never a subnet. Set to your Nginx LXC IP.
TRUSTED_PROXIES=192.168.1.130
